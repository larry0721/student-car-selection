{
  "name": "student-car-selection",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint app components data lib types next.config.ts tailwind.config.ts",
    "typecheck": "tsc --noEmit",
    "test:data": "node --experimental-strip-types scripts/test_vehicle_validation.mjs",
    "test:recommendations": "tsc -p tsconfig.recommendation-tests.json && node /private/tmp/student-car-selection-recommendation-tests/scripts/test_recommendation_profiles.js",
    "test:recommendation-objects": "tsc -p tsconfig.recommendation-tests.json && node /private/tmp/student-car-selection-recommendation-tests/scripts/test_recommendation_objects.js",
    "test:qualification": "tsc -p tsconfig.recommendation-tests.json && node /private/tmp/student-car-selection-recommendation-tests/scripts/test_qualification_engine.js",
    "test:pipeline": "tsc -p tsconfig.recommendation-tests.json && node /private/tmp/student-car-selection-recommendation-tests/scripts/test_candidate_pipeline.js",
    "test:decision-report": "tsc -p tsconfig.recommendation-tests.json && node /private/tmp/student-car-selection-recommendation-tests/scripts/test_priority_scaling_decision_report.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "next": "16.2.9",
    "openai": "6.45.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.6.0",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  }
}
